<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /compliance/ce/

    # Requests already inside public/ pass through — prevents rewrite loops
    RewriteRule ^public/ - [L]

    # Forward everything else (including bare directory requests) into public/
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>
