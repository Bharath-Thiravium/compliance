<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /compliance/ce/

    # Block direct access to sensitive files and directories
    RewriteRule ^\.env - [F,L]
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|vendor|tests)/ - [F,L]
    RewriteRule ^(composer\.(json|lock)|artisan|deploy\.sh)$ - [F,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect trailing slashes
    RewriteCond %{REQUEST_URI} ^/compliance/ce/(.+)/$
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ /compliance/ce/%1 [L,R=301]

    # Serve static assets (css, js, images, fonts) from public/ if they exist
    RewriteCond %{REQUEST_URI} ^/compliance/ce/(.+)$
    RewriteCond %{DOCUMENT_ROOT}/compliance/ce/public/%1 -f
    RewriteRule ^(.+)$ public/$1 [L,QSA]

    # Everything else goes to the root index.php (Laravel entry point)
    RewriteRule ^ index.php [L,QSA]
</IfModule>
