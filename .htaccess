<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block sensitive files
    RewriteRule ^\.env - [F,L]
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|vendor|tests)/ - [F,L]
    RewriteRule ^(composer\.(json|lock)|artisan|deploy\.sh)$ - [F,L]

    # Auth headers
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # If the request is already a real file or directory, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # If the file exists inside public/, serve it from there
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond public/%{REQUEST_URI} -f
    RewriteRule ^(.+)$ public/$1 [L,QSA]

    # Everything else goes to Laravel
    RewriteRule ^ index.php [L,QSA]
</IfModule>
