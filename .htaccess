<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block sensitive files
    RewriteRule ^\.env - [F,L]
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|vendor|tests)/ - [F,L]
    RewriteRule ^(composer\.(json|lock)|artisan|deploy\.sh)$ - [F,L]

    # Auth headers
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Serve real files and directories directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Serve from public/ if file exists there (works on both local and production)
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} !-f
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} !-d
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # Everything else goes to Laravel
    RewriteRule ^ index.php [L,QSA]
</IfModule>
