<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block sensitive files
    RewriteRule ^\.env - [F,L]
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|vendor|tests)/ - [F,L]
    RewriteRule ^(composer\.(json|lock)|artisan|deploy\.sh)$ - [F,L]

    # Auth headers
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Pass real files and directories through directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # LOCAL: serve static assets from public/ (localhost)
    RewriteCond %{HTTP_HOST} ^localhost$ [OR]
    RewriteCond %{HTTP_HOST} ^127\.0\.0\.1$
    RewriteCond %{DOCUMENT_ROOT}/compliance/public/%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # PRODUCTION: serve static assets from public/ (athenas.co.in)
    RewriteCond %{HTTP_HOST} !^localhost$
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$
    RewriteCond %{DOCUMENT_ROOT}/compliance/ce/public/%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # Everything else goes to Laravel entry point
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L,QSA]
</IfModule>
